{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiorg/schemas/memory-node/v1.0.0",
  "title": "MemoryNode",
  "description": "Single memory node metadata schema for telegram-ai-org storage layer",
  "type": "object",
  "required": ["id", "title", "type", "created_at", "updated_at", "file_path"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_-]+-[0-9]{8}-[a-z0-9]{6}$",
      "description": "Unique node identifier. Format: {TYPE_PREFIX}-{YYYYMMDD}-{6-char-hash}. E.g. TASK-20260322-a1b2c3",
      "examples": ["TASK-20260322-a1b2c3", "MEM-20260322-f4e5d6", "RETRO-20260319-91k2m3"]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Human-readable title of this memory node"
    },
    "type": {
      "type": "string",
      "enum": [
        "task",
        "memory",
        "retro",
        "decision",
        "report",
        "skill",
        "prd",
        "research",
        "weekly",
        "eval",
        "design",
        "conversation"
      ],
      "description": "Node type — determines which directory it lives in and how it is indexed"
    },
    "importance": {
      "type": "string",
      "enum": ["CORE", "HIGH", "MEDIUM", "LOW"],
      "default": "MEDIUM",
      "description": "Importance tier. CORE = always loaded, HIGH = loaded on demand, LOW = archive-only"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "archived",
        "draft",
        "deprecated",
        "in-progress",
        "blocked"
      ],
      "default": "active"
    },
    "file_path": {
      "type": "string",
      "description": "Relative path from project root to the source .md file. E.g. memory/tasks/T-260.md"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 last-modified timestamp"
    },
    "valid_until": {
      "type": ["string", "null"],
      "format": "date-time",
      "default": null,
      "description": "Expiry timestamp. null = never expires. After this time, node is demoted to archived."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["namespace", "value"],
        "properties": {
          "namespace": {
            "type": "string",
            "enum": ["domain", "org", "phase", "tech", "status", "custom"],
            "description": "Tag namespace for grouping. E.g. domain:memory, org:engineering, tech:python"
          },
          "value": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        }
      },
      "description": "Namespaced tags. E.g. [{namespace: 'domain', value: 'memory'}, {namespace: 'tech', value: 'python'}]"
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "LLM-generated one-paragraph summary for semantic search context"
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 20,
      "description": "LLM-extracted keyword list for fast keyword matching (supplement to semantic search)"
    },
    "relations": {
      "type": "array",
      "items": { "$ref": "#/$defs/RelationRef" },
      "description": "Outgoing relations from this node to other nodes"
    },
    "meta_generated_by": {
      "type": ["string", "null"],
      "description": "Which model generated this metadata. E.g. gemini-2.5-flash, claude-haiku-3",
      "default": null
    },
    "meta_confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1,
      "description": "LLM confidence score for auto-generated metadata (0.0–1.0). null if human-written.",
      "default": null
    },
    "vector_id": {
      "type": ["string", "null"],
      "description": "External vector DB document ID (ChromaDB / Qdrant). null if not yet embedded.",
      "default": null
    },
    "org": {
      "type": ["string", "null"],
      "enum": [
        "engineering",
        "product",
        "design",
        "research",
        "growth",
        "ops",
        "pm",
        null
      ],
      "default": null,
      "description": "Originating organization bot"
    }
  },
  "$defs": {
    "RelationRef": {
      "type": "object",
      "required": ["target_id", "relation_type"],
      "additionalProperties": false,
      "properties": {
        "target_id": {
          "type": "string",
          "description": "ID of the target node"
        },
        "relation_type": {
          "type": "string",
          "enum": [
            "parent",
            "child",
            "implements",
            "references",
            "extends",
            "contradicts",
            "triggers",
            "validates",
            "supersedes",
            "related",
            "depends_on",
            "blocks"
          ]
        },
        "label": {
          "type": ["string", "null"],
          "maxLength": 100,
          "description": "Optional human-readable label for the relation edge",
          "default": null
        },
        "strength": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0,
          "description": "Edge weight: 1.0 = strong/explicit, lower = inferred/weak"
        }
      }
    }
  }
}
