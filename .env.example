# ─── PM Bot ───────────────────────────────────────────────────
PM_BOT_TOKEN=           # @BotFather에서 발급
TELEGRAM_GROUP_CHAT_ID= # 그룹 chat_id (음수값)

# ─── LLM (PM 라우팅용) ────────────────────────────────────────
OPENAI_API_KEY=          # GPT 라우팅 사용 시
PM_MODEL=gpt-4o          # 또는 gpt-5.4

# ─── Claude Code Runner ───────────────────────────────────────
CLAUDE_CLI_PATH=claude   # claude CLI 경로 (기본: PATH에서 탐색)

# ─── Workers (workers.yaml에서 토큰 관리) ─────────────────────
# 각 워커 봇 토큰은 workers.yaml 참고
