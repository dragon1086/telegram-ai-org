# Telegram Bot Tokens
PM_BOT_TOKEN=your_pm_bot_token_here
DEV_BOT_TOKEN=your_dev_bot_token_here
ANALYST_BOT_TOKEN=your_analyst_bot_token_here
DOCS_BOT_TOKEN=your_docs_bot_token_here

# Telegram Group Chat ID (음수)
TELEGRAM_GROUP_CHAT_ID=-1001234567890

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Context DB
CONTEXT_DB_PATH=~/.ai-org/context.db

# Claude Code CLI 경로
CLAUDE_CLI_PATH=/usr/local/bin/claude

# Codex CLI 경로 (선택)
CODEX_CLI_PATH=/usr/local/bin/codex

# 로그 레벨
LOG_LEVEL=INFO

# 봇 화이트리스트 (콤마 구분 username)
BOT_WHITELIST=pm_bot,dev_bot,analyst_bot,docs_bot
