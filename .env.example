# =============================================================================
# telegram-ai-org 환경변수 설정 파일
# 이 파일을 .env 로 복사한 뒤 각 값을 채워주세요:
#   cp .env.example .env
# =============================================================================

# =============================================================================
# [필수] 텔레그램 봇 토큰
# @BotFather 에서 봇을 생성하여 발급받은 토큰
# =============================================================================

# PM 글로벌 봇 토큰 (필수) — docker-compose / PyPI 배포 표준 변수명
TELEGRAM_BOT_TOKEN=
# 하위 호환: 기존 설정 유지 (PM_BOT_TOKEN 과 동일)
PM_BOT_TOKEN=

# 그룹 채팅 ID — 음수값, 예: -5203707291 (필수)
# 방법: 그룹에 @userinfobot 초대 후 메시지 전송
TELEGRAM_GROUP_CHAT_ID=

# 부서 봇 토큰 (필수 — 해당 부서를 사용할 경우)
BOT_TOKEN_AIORG_PRODUCT_BOT=      # 기획실
BOT_TOKEN_AIORG_ENGINEERING_BOT=  # 개발실
BOT_TOKEN_AIORG_DESIGN_BOT=       # 디자인실 (codex 엔진)
BOT_TOKEN_AIORG_GROWTH_BOT=       # 성장실 (gemini-cli 엔진)
BOT_TOKEN_AIORG_OPS_BOT=          # 운영실 (codex 엔진)
BOT_TOKEN_AIORG_RESEARCH_BOT=     # 리서치실 (gemini-cli 엔진)

# 추가 팀 PM 토큰 (선택 — 별도 팀 구성 시)
MKT_PM_TOKEN=   # 마케팅 팀 PM 봇 토큰
DEV_PM_TOKEN=   # 개발 팀 PM 봇 토큰

# Watchdog 전용 봇 토큰 (선택 — PM_BOT_TOKEN 대체)
WATCHDOG_BOT_TOKEN=

# Watchdog 전용 채팅 ID (선택 — TELEGRAM_GROUP_CHAT_ID 대체)
WATCHDOG_CHAT_ID=

# =============================================================================
# [필수] API 키 — LLM Confidence Scoring 및 엔진용
# 우선순위: GEMINI_API_KEY → ANTHROPIC_API_KEY → DEEPSEEK_API_KEY → keyword fallback
# OPENAI_API_KEY는 제거됨 — Codex CLI는 ~/.codex/auth.json OAuth 사용
# =============================================================================

# Google Gemini API 키 (권장 — gemini-2.5-flash 모델 사용)
GEMINI_API_KEY=
GOOGLE_API_KEY=   # GEMINI_API_KEY의 대체 키 (선택)

# Anthropic REST API 키 (선택 — GEMINI 없을 때 대체)
ANTHROPIC_API_KEY=

# DeepSeek API 키 (선택 — 최하위 대체)
DEEPSEEK_API_KEY=

# =============================================================================
# [엔진] === Claude Code ===
# claude CLI 기반 실행 엔진 (개발실·기획실·PM 기본 엔진)
# =============================================================================

# Claude Code OAuth 토큰 (필수 — claude CLI 인증용)
# 발급: claude 명령 실행 후 브라우저 로그인
CLAUDE_CODE_OAUTH_TOKEN=

# claude CLI 실행 파일 경로 (선택 — setup.sh 가 자동 감지)
# 기본값: /Users/rocky/.local/bin/claude
CLAUDE_CLI_PATH=

# Claude Code 태스크 기본 타임아웃 (선택, 초 단위, 기본값: 14400 = 4시간)
CLAUDE_DEFAULT_TIMEOUT_SEC=14400

# 실험적 에이전트 팀 기능 활성화 (선택, 1=활성화)
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=0

# =============================================================================
# [엔진] === Codex ===
# OpenAI Codex CLI 기반 실행 엔진 (운영실·디자인실 기본 엔진)
# 인증 우선순위: ~/.codex/auth.json (OAuth) → OPENAI_API_KEY (API 키)
# OAuth 인증: codex login 실행 후 브라우저 인증 (권장)
# =============================================================================

# OpenAI API 키 (선택 — OAuth 없을 때 대체 인증)
# OAuth 인증이 완료된 경우 불필요 (~/.codex/auth.json 존재 시)
OPENAI_API_KEY=

# codex CLI 실행 파일 경로 (선택 — setup.sh 가 자동 감지)
# 기본값: /opt/homebrew/bin/codex
CODEX_CLI_PATH=

# Codex 기본 타임아웃 (선택, 초 단위, 기본값: 1800 = 30분)
CODEX_DEFAULT_TIMEOUT_SEC=1800

# Codex 복잡 태스크 타임아웃 (선택, 초 단위, 기본값: 14400 = 4시간)
CODEX_COMPLEX_TIMEOUT_SEC=14400

# Codex 리포지토리 검색 루트 경로 (선택, 콜론으로 구분)
CODEX_REPO_SEARCH_ROOTS=

# =============================================================================
# [엔진] === Gemini CLI ===
# Google Gemini CLI 기반 실행 엔진 (성장실·리서치실 기본 엔진)
# 인증: OAuth 2.0 (~/.gemini/oauth_creds.json)
# =============================================================================

# gemini CLI 실행 파일 경로 (선택 — setup.sh 가 자동 감지)
# Homebrew 설치: brew install gemini-cli → /opt/homebrew/bin/gemini
# npm 설치:      npm install -g @google/gemini-cli
GEMINI_CLI_PATH=/opt/homebrew/bin/gemini

# Gemini CLI 기본 타임아웃 (선택, 초 단위, 기본값: 1800 = 30분)
# 긴 리서치 태스크에 대응하기 위해 30분으로 설정
GEMINI_CLI_DEFAULT_TIMEOUT_SEC=1800

# Gemini CLI 기본 모델 (선택, 기본값: gemini-2.5-flash)
# 주의: gemini-2.0-flash는 2026-06-01 서비스 종료 예정 — 사용 금지
# 주의: gemini-3.x는 Preview 단계 — 프로덕션 사용 자제
GEMINI_CLI_MODEL=gemini-2.5-flash

# =============================================================================
# [엔진 선택] 기본 실행 엔진 (setup.sh가 자동 감지 후 채워줌)
# 선택 가능한 값: claude-code | codex | gemini-cli
# =============================================================================

# 기본 엔진 (auto-detected by setup.sh — 직접 수정 가능)
ENGINE=

# 런타임 참조 표준 변수 (setup.sh가 ENGINE= 과 동시에 자동 기재)
# 봇 런타임, 오케스트레이터에서 이 변수를 우선 참조
ACTIVE_ENGINE=

# docker-compose ENGINE_TYPE 환경변수 (docker-compose.yml 표준 변수명)
# 선택 가능한 값: claude-code | codex | gemini-cli
# docker compose up 시 각 서비스(claude-engine/codex-engine/gemini-engine)가 자동으로 설정함
ENGINE_TYPE=

# =============================================================================
# [기능 플래그] Feature Flags
# 0=비활성화, 1=활성화
# =============================================================================

# PM 중앙 통제 모드 (1: PM 봇이 모든 태스크를 직접 디스패치)
ENABLE_PM_ORCHESTRATOR=1

# 부서간 토론 프로토콜 (1: Discussion 멀티라운드 활성화)
ENABLE_DISCUSSION_PROTOCOL=1

# 태스크 의존성 자동 디스패치 (1: 의존 태스크 자동 처리)
ENABLE_AUTO_DISPATCH=1

# Codex↔Claude Code 교차 검증 (1: 결과를 서로 교차 검증)
ENABLE_CROSS_VERIFICATION=1

# PM 목표 달성 루프 GoalTracker (1: 권장, 목표 추적 활성화)
ENABLE_GOAL_TRACKER=1

# =============================================================================
# [자율 에이전트] Autonomous Mode
# =============================================================================

# 자율 실행 모드 (true: 사용자 입력 없이 인터랙티브 스킬 자동 응답)
# 사용 예: AUTONOMOUS_MODE=true claude --dangerously-skip-permissions "..."
AUTONOMOUS_MODE=false

# =============================================================================
# [DB/스토리지] 데이터베이스 및 파일 경로
# =============================================================================

# Context DB 경로 (선택, 기본값: ~/.ai-org/context.db)
CONTEXT_DB_PATH=~/.ai-org/context.db

# 공유 메모리 JSON 경로 (선택, 기본값: ~/.ai-org/shared_memory.json)
SHARED_MEMORY_PATH=~/.ai-org/shared_memory.json

# 리포트 저장 디렉토리 (선택, 기본값: ./reports)
AIORG_REPORT_DIR=./reports

# MCP 서버용 DB 경로 (선택, 기본값: ~/.ai-org/context.db)
DB_PATH=~/.ai-org/context.db

# MCP 서버 봇 식별자 (선택)
BOT_ID=unknown

# =============================================================================
# [봇 동작] 타임아웃 및 하트비트 설정
# =============================================================================

# 봇 무응답 타임아웃 (선택, 초 단위, 기본값: 120)
BOT_IDLE_TIMEOUT_SEC=300

# 하트비트 전송 간격 (선택, 초 단위, 기본값: 30)
BOT_HB_INTERVAL_SEC=30

# 봇 절대 상한 타임아웃 (선택, 초 단위, 기본값: 1800 = 30분)
BOT_MAX_TIMEOUT_SEC=1800

# PM 채팅 응답 대기 타임아웃 (선택, 초 단위, 기본값: 300)
PM_CHAT_REPLY_TIMEOUT_SEC=300

# 동시 실행 PM 봇 수 (선택, 기본값: 1)
PM_COUNT=1

# 조직 이름 식별자 (선택, 기본값: global)
PM_ORG_NAME=global

# =============================================================================
# [비용/성능 제한] API 비용 및 서킷 브레이커
# =============================================================================

# 시간당 API 호출 상한 (선택, 기본값: 100)
PM_HOURLY_CALL_LIMIT=40

# 일일 비용 상한 USD (선택, 기본값: 50.0)
DAILY_COST_LIMIT_USD=50.0

# 토큰 1000개당 비용 USD (선택, 기본값: 0.003)
COST_PER_1K_TOKENS_USD=0.003

# 서킷 브레이커 오류 임계치 (선택, 기본값: 3)
CIRCUIT_BREAKER_ERROR_THRESHOLD=3

# 서킷 브레이커 리셋 시간 (선택, 초 단위, 기본값: 600)
CIRCUIT_BREAKER_RESET_SEC=300

# =============================================================================
# [Staleness 체크] 태스크 신선도 모니터링
# =============================================================================

# 스탈 임계값 (선택, 초 단위, 기본값: 300)
STALE_THRESHOLD_SEC=300

# 하트비트 그레이스 시간 (선택, 초 단위, 기본값: 120)
HEARTBEAT_GRACE_SEC=120

# 서브태스크 타임아웃 (선택, 초 단위, 기본값: 600)
SUBTASK_TIMEOUT_SEC=600

# 스탈 체크 인터벌 (선택, 초 단위, 기본값: 60)
STALENESS_CHECK_INTERVAL_SEC=60

# =============================================================================
# [컨텍스트 윈도우] LLM 컨텍스트 크기 제한
# =============================================================================

# 히스토리 최대 메시지 수 (선택, 기본값: 20)
MAX_HISTORY_MESSAGES=20

# 히스토리 최대 토큰 수 (선택, 기본값: 6000)
MAX_HISTORY_TOKENS=6000

# =============================================================================
# [PM 오케스트레이터] 태스크 동시성 제한
# =============================================================================

# 재작업 최대 재시도 횟수 (선택, 기본값: 2)
MAX_REWORK_RETRIES=2

# 동시 부모 태스크 최대 수 (선택, 기본값: 10)
MAX_CONCURRENT_PARENT_TASKS=10

# Claim TTL (선택, 초 단위, 기본값: 600 = 10분)
CLAIM_TTL_SEC=600

# 텍스트 해시 중복 방지 TTL (선택, 초 단위, 기본값: 86400 = 24시간)
TEXT_HASH_TTL_SEC=86400

# =============================================================================
# [첨부파일 분석] 비전 브리지 (선택 기능)
# =============================================================================

# 이미지 분석 브리지 명령어 (선택)
ATTACHMENT_VISION_BRIDGE_CMD=

# 멀티모달 브리지 명령어 (선택)
ATTACHMENT_MULTIMODAL_BRIDGE_CMD=

# 비전 브리지 타임아웃 (선택, 초 단위, 기본값: 60)
ATTACHMENT_VISION_BRIDGE_TIMEOUT_SEC=60

# =============================================================================
# [로깅] 로그 레벨 및 디버그 설정
# =============================================================================

# 로그 레벨 (선택, 기본값: INFO)
# 선택 가능한 값: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# 디버그 모드 (선택, false=비활성화)
# true 시 상세 트레이스, 원시 API 요청/응답 출력
AIORG_DEBUG=false

# =============================================================================
# [디스플레이] UI 설정
# =============================================================================

# 메시지 디스플레이 제한기 활성화 (선택, true/false, 기본값: true)
USE_DISPLAY_LIMITER=true

# 터미널 색상 비활성화 (선택, 값이 있으면 색상 off)
# NO_COLOR=1

# =============================================================================
# [E2E 테스트 전용] Telegram MTProto API (일반 운영 시 불필요)
# my.telegram.org 에서 발급
# =============================================================================

# Telegram API ID (E2E 테스트 스크립트 전용)
TELEGRAM_API_ID=

# Telegram API Hash (E2E 테스트 스크립트 전용)
TELEGRAM_API_HASH=

# 등록된 전화번호 (E2E 테스트 스크립트 전용)
TELEGRAM_PHONE=
