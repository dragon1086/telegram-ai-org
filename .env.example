# ─── Global PM Bot ────────────────────────────────────────────
PM_BOT_TOKEN=           # 글로벌 PM 봇 토큰 (@BotFather에서 발급)
TELEGRAM_GROUP_CHAT_ID= # 그룹 chat_id (음수값, 예: -5203707291)

# ─── PM 오케스트레이터 봇 (ENABLE_PM_ORCHESTRATOR=1 시 필수) ──
# PM_BOT_TOKEN을 PM 오케스트레이터 봇 토큰으로 사용 (위에서 이미 설정)

# ─── 부서 봇 토큰 ──────────────────────────────────────────────
BOT_TOKEN_AIORG_PRODUCT_BOT=     # 기획실
BOT_TOKEN_AIORG_ENGINEERING_BOT= # 개발실
BOT_TOKEN_AIORG_DESIGN_BOT=      # 디자인실
BOT_TOKEN_AIORG_GROWTH_BOT=      # 성장실
BOT_TOKEN_AIORG_OPS_BOT=         # 운영실

# ─── LLM (confidence scoring용) ──────────────────────────────
GEMINI_API_KEY=          # Gemini scoring (권장, gemini-3-flash-preview)
OPENAI_API_KEY=          # OpenAI scoring (대체)
ANTHROPIC_API_KEY=       # Anthropic REST API scoring (대체)
DEEPSEEK_API_KEY=        # DeepSeek scoring (대체)
# 우선순위: GEMINI → OPENAI → ANTHROPIC → DEEPSEEK → keyword fallback

# ─── Claude Code Runner ───────────────────────────────────────
CLAUDE_CODE_OAUTH_TOKEN= # Claude Code OAuth 토큰 (claude CLI 인증용)
CLAUDE_CLI_PATH=/Users/rocky/.local/bin/claude  # claude CLI 경로

# ─── Feature Flags (모두 끄면 기존 경쟁입찰 모드) ─────────────
ENABLE_PM_ORCHESTRATOR=0   # 1: PM 중앙 통제 (부서봇 입찰 건너뜀)
ENABLE_DISCUSSION_PROTOCOL=0  # 1: 부서간 토론 프로토콜 활성화
ENABLE_AUTO_DISPATCH=0     # 1: 태스크 의존성 자동 디스패치
ENABLE_CROSS_VERIFICATION=0   # 1: codex↔claude-code 교차 검증
ENABLE_GOAL_TRACKER=0         # 1: PM 목표 달성 루프 (GoalTracker)

# ─── 자율 에이전트 모드 ────────────────────────────────────────
AUTONOMOUS_MODE=false
# true: 코딩 에이전트가 brainstorming 등 인터랙티브 스킬을 만났을 때
#       사용자 입력 없이 컨텍스트 기반으로 자동 응답한다.
# 자율 실행 시: AUTONOMOUS_MODE=true claude --dangerously-skip-permissions "..."
