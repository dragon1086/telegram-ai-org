# ──────────────────────────────────────────
# PM 봇 (필수)
# ──────────────────────────────────────────
PM_BOT_TOKEN=your_pm_bot_token_here
TELEGRAM_GROUP_CHAT_ID=-1001234567890

# ──────────────────────────────────────────
# 워커 봇 토큰 (workers.yaml 참조)
# workers.yaml에서 ${VAR_NAME} 형식으로 참조됨
# ──────────────────────────────────────────
COKAC_BOT_TOKEN=your_cokac_bot_token_here
# RESEARCHER_BOT_TOKEN=your_researcher_bot_token_here
# WRITER_BOT_TOKEN=your_writer_bot_token_here

# ──────────────────────────────────────────
# 실행 엔진 (선택)
# ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_CLI_PATH=/usr/local/bin/claude
# CODEX_CLI_PATH=/usr/local/bin/codex

# ──────────────────────────────────────────
# 기타
# ──────────────────────────────────────────
CONTEXT_DB_PATH=~/.ai-org/context.db
LOG_LEVEL=INFO
